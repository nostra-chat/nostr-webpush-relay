# nostr-webpush-relay environment

# Generate VAPID keys with: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nostra.chat

PORT=8787
DB_PATH=/data/relay.db

# Default relays used when a subscription doesn't specify any.
DEFAULT_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.snort.social

# Limits
MAX_RELAYS_PER_SUB=5

# NIP-98 timestamp tolerance (seconds)
NIP98_CLOCK_SKEW_SEC=60

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# Allowed cross-origin requesters for the HTTP API (comma-separated).
# Browsers enforce CORS for /info and /subscription/* — without this header
# the Nostra.chat client silently fails to fetch the VAPID key and never
# subscribes. Use '*' only for public dev relays.
ALLOWED_ORIGINS=https://nostra.chat
